datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?   // Nomor WA
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  tickets       Ticket[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  targetType String
  targetId  String?
  actorEmail String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorEmail])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Ticket {
  id        String   @id @default(cuid())
  userId    String
  asal      String
  tujuan    String
  tanggal   String
  jam       String
  harga     Int
  coach     String?
  seat      String?
  kelas     String?
  image     String
  status    String   @default("available") // available, sold
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
